{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tanstack-start-app",
	"compatibility_date": "2025-09-24",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "src/server.ts",
	"r2_buckets": [
		{
			"bucket_name": "corrida8020-assets",
			"binding": "corrida8020_assets"
		}
	],
}